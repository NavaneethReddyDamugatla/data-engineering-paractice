import sqlite3

# Connect to SQLite database (creates file if it doesn't exist)
conn = sqlite3.connect('practice_database.db')
cursor = conn.cursor()

# Create tables
cursor.execute('''
CREATE TABLE IF NOT EXISTS departments (
    dept_id INTEGER PRIMARY KEY,
    dept_name TEXT NOT NULL,
    location TEXT
)
''')

cursor.execute('''
CREATE TABLE IF NOT EXISTS employees (
    emp_id INTEGER PRIMARY KEY,
    name TEXT NOT NULL,
    age INTEGER,
    salary REAL,
    dept_id INTEGER,
    FOREIGN KEY (dept_id) REFERENCES departments (dept_id)
)
''')

# Insert sample data
departments_data = [
    (1, 'Engineering', 'Building A'),
    (2, 'Sales', 'Building B'),
    (3, 'Marketing', 'Building C'),
    (4, 'HR', 'Building A')
]

employees_data = [
    (1, 'John Doe', 30, 75000.00, 1),
    (2, 'Jane Smith', 28, 65000.00, 2),
    (3, 'Bob Johnson', 35, 80000.00, 1),
    (4, 'Alice Brown', 26, 55000.00, 3),
    (5, 'Charlie Wilson', 42, 90000.00, 1),
    (6, 'Diana Davis', 31, 70000.00, 2)
]

cursor.executemany('INSERT OR IGNORE INTO departments VALUES (?, ?, ?)', departments_data)
cursor.executemany('INSERT OR IGNORE INTO employees VALUES (?, ?, ?, ?, ?)', employees_data)

conn.commit()

print('Database created and sample data inserted successfully!')
print('\n' + '='*50)

# Practice SQL Queries

print('\n1. SELECT ALL EMPLOYEES:')
cursor.execute('SELECT * FROM employees')
results = cursor.fetchall()
for row in results:
    print(row)

print('\n2. SELECT EMPLOYEES WITH SALARY > 70000:')
cursor.execute('SELECT name, salary FROM employees WHERE salary > 70000')
results = cursor.fetchall()
for row in results:
    print(f'{row[0]}: ')

print('\n3. JOIN EMPLOYEES WITH DEPARTMENTS:')
cursor.execute('''
SELECT e.name, e.age, e.salary, d.dept_name, d.location
FROM employees e
JOIN departments d ON e.dept_id = d.dept_id
''')
results = cursor.fetchall()
for row in results:
    print(f'{row[0]} ({row[1]} years old) - {row[2]} - {row[3]} ({row[4]})')

print('\n4. GROUP BY DEPARTMENT WITH AVERAGE SALARY:')
cursor.execute('''
SELECT d.dept_name, COUNT(e.emp_id) as emp_count, AVG(e.salary) as avg_salary
FROM departments d
LEFT JOIN employees e ON d.dept_id = e.dept_id
GROUP BY d.dept_id, d.dept_name
''')
results = cursor.fetchall()
for row in results:
    print(f'{row[0]}: {row[1]} employees, Average Salary: ')

print('\n5. UPDATE SALARY EXAMPLE:')
cursor.execute('UPDATE employees SET salary = salary * 1.10 WHERE age > 35')
conn.commit()
print('Updated salaries for employees over 35 years old by 10%')

print('\n6. DELETE EXAMPLE:')
cursor.execute('DELETE FROM employees WHERE age < 25')
conn.commit()
print('Deleted employees under 25 years old')

print('\n7. FINAL EMPLOYEE LIST:')
cursor.execute('SELECT name, age, salary FROM employees ORDER BY salary DESC')
results = cursor.fetchall()
for row in results:
    print(f'{row[0]}: Age {row[1]}, Salary ')

# Close connection
conn.close()

print('\n' + '='*50)
print('SQL Practice Complete!')
print('You can modify this script to practice more SQL queries.')
print('The database file practice_database.db has been created in your workspace.')
